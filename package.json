{
    "name": "rampkit",
    "version": "2.0.0",
    "description": "Reversible Action Management Protocol - A methodology for governing decision velocity based on reversibility",
    "main": "src/index.js",
    "type": "module",
    "bin": {
        "ramp": "./src/index.js",
        "ramp-kit": "./src/index.js",
        "rampkit": "./src/index.js"
    },
    "scripts": {
        "start": "node src/index.js",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
        "test:security": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=security",
        "lint": "eslint src/",
        "prepare": "chmod +x src/index.js"
    },
    "keywords": [
        "ramp",
        "reversibility",
        "decision-making",
        "governance",
        "velocity",
        "bezos",
        "two-way-door",
        "one-way-door",
        "rollback",
        "cli",
        "devops",
        "cicd"
    ],
    "author": "Naveen Riaz Mohamed Kani <synthai@synthai.biz>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/synthanai/ramp-kit.git"
    },
    "homepage": "https://github.com/synthanai/ramp-kit#readme",
    "bugs": {
        "url": "https://github.com/synthanai/ramp-kit/issues"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "boxen": "^7.1.1",
        "chalk": "^5.3.0",
        "cli-table3": "^0.6.3",
        "commander": "^11.1.0",
        "inquirer": "^9.2.12",
        "ora": "^8.0.1"
    },
    "devDependencies": {
        "eslint": "^8.55.0",
        "jest": "^29.7.0"
    },
    "files": [
        "src/",
        "data/",
        "methodology/",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ]
}